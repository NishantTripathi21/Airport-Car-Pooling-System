{
  "name": "car-pooling-system",
  "version": "1.0.0",
  "description": "Smart backend system for airport ride pooling with insertion heuristic and dynamic pricing",
  "main": "src/server.ts",
  "type": "module",
  "scripts": {
    "dev:server": "nodemon --exec tsx src/server.ts",
    "dev:worker": "nodemon --exec tsx src/worker.ts",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:worker\"",
    "build": "tsc --project tsconfig.json",
    "start:server": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@prisma/client": "^7.5.0",
    "amqplib": "^0.10.9",
    "express": "^4.18.2",
    "ioredis": "^5.10.1",
    "redis": "^4.6.13",
    "uuid": "^9.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/redis": "^4.0.11",
    "@types/uuid": "^9.0.7",
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "prisma": "^7.5.0",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
